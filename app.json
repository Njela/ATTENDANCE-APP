{
  "expo": {
    "name": "AttendTrack",
    "slug": "attendtrack",
    "version": "1.0.0",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A3C8F"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.khakasa.attendtrack",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1A3C8F"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    }
  }
}